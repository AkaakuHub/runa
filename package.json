{
	"name": "miurd",
	"version": "1.0.0",
	"description": "A Discord bot that responds to specific messages.",
	"main": "src/index.ts",
	"packageManager": "pnpm@10.12.1",
	"engines": {
		"node": "24.1.0"
	},
	"scripts": {
		"start": "tsx src/index.ts",
		"build": "tsc",
		"dev": "tsx watch src/index.ts",
		"admin": "tsx src/admin/server.ts",
		"deploy": "tsx src/deploy-commands.ts --reset",
		"reset": "tsx src/deploy-commands.ts --reset-global",
		"reset:only": "tsx src/deploy-commands.ts --reset --reset-global --reset-only",
		"lint": "pnpm biome lint --write ./src",
		"format": "pnpm biome format --write ./src",
		"knip": "knip",
		"voicevox:setup": "./scripts/setup-voicevox.sh",
		"voicevox:start": "./scripts/start-voicevox.sh start",
		"voicevox:start:host": "./scripts/start-voicevox.sh start --host",
		"voicevox:stop": "./scripts/start-voicevox.sh stop",
		"voicevox:status": "./scripts/start-voicevox.sh status",
		"voicevox:restart": "./scripts/start-voicevox.sh restart",
		"searxng:start": "docker compose -f compose.searxng.yml up -d",
		"searxng:stop": "docker compose -f compose.searxng.yml down",
		"searxng:logs": "docker compose -f compose.searxng.yml logs -f searxng",
		"sudachi:setup": "./scripts/setup-sudachi.sh",
		"start:voicevox": "TTS_PROVIDER=voicevox concurrently \"pnpm run voicevox:start\" \"pnpm run dev\"",
		"start:curlvoice": "TTS_PROVIDER=curlvoice pnpm run dev"
	},
	"dependencies": {
		"@discordjs/opus": "^0.10.0",
		"@discordjs/voice": "^0.19.2",
		"@google/genai": "^1.51.0",
		"@snazzah/davey": "^0.1.11",
		"@types/d3": "^7.4.3",
		"@types/jsdom": "^28.0.0",
		"@types/node-cron": "^3.0.11",
		"abcjs": "^6.6.2",
		"d3": "^7.9.0",
		"discord.js": "^14.26.4",
		"dotenv": "^17.3.1",
		"ffmpeg-static": "^5.3.0",
		"jsdom": "^28.1.0",
		"libsodium-wrappers": "^0.8.2",
		"node-cron": "^4.2.1",
		"opusscript": "^0.1.1",
		"playwright": "^1.59.1",
		"prism-media": "^1.3.5",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"sharp": "^0.34.5",
		"tsx": "^4.21.0",
		"winston": "^3.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@eslint/js": "^10.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"concurrently": "^9.2.1",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"knip": "^5.86.0",
		"lefthook": "^2.1.3",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	}
}
